# Segredo usado para assinar/validar os JWTs emitidos em POST /auth/login.
JWT_SECRET=troque-esta-chave-por-uma-string-longa-e-aleatoria

# Caminho do arquivo de auditoria/eventos (historico de insert/update/
# delete de usuarios, clientes, produtos e pedidos). Se omitido, o padrao
# e "auditoria.txt" na pasta onde o processo foi iniciado.
#
# IMPORTANTE (Semana 11): desde esta semana este arquivo tambem e lido de
# volta no boot para reidratar o cache em memoria - ele passou a guardar o
# hash bcrypt da senha de cada usuario (nunca a senha em texto puro), sem
# o qual nao seria possivel reconstruir o login apos um restart. Trate
# este arquivo com o mesmo cuidado que um dump de banco de dados: nunca
# faca commit dele (ja esta no .gitignore) e restrinja o acesso a ele.
AUDIT_LOG_PATH=auditoria.txt
