# Segredo usado para assinar/validar os JWTs emitidos em POST /auth/login.
JWT_SECRET=troque-esta-chave-por-uma-string-longa-e-aleatoria

# Caminho do arquivo de auditoria (historico de insert/update/delete de
# usuarios e clientes). Se omitido, o padrao e "auditoria.txt" na pasta
# onde o processo foi iniciado.
AUDIT_LOG_PATH=auditoria.txt
