# "memory" (padrao, nao precisa configurar nada) roda com SQLite em
# memoria, criado do zero a cada "cargo run". "postgres" usa o banco real
# e exige DATABASE_URL preenchido.
DATABASE_BACKEND=memory

DATABASE_URL=postgres://postgres:postgres@localhost:5432/auth_api
JWT_SECRET=troque-esta-chave-por-uma-string-longa-e-aleatoria
